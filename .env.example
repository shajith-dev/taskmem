# taskmem uses an embedded SQLite database and needs no configuration.
# By default the database lives under your user config directory:
#   Windows: %AppData%\taskmem\taskmem.db
#   Linux:   ~/.config/taskmem/taskmem.db
#   macOS:   ~/Library/Application Support/taskmem/taskmem.db
#
# Override the location only if you want a custom path (e.g. per-project):
# DATABASE_URL=./taskmem.db

APP_ENV=development
